# Configuración de Base de Datos
# Ejemplo: postgres://usuario:contraseña@servidor.net:1087/nombre-db?sslmode=disable
DATABASE_URL="postgres://postgres:password@localhost:5432/aurum-leasing-db"

# Configuración de Seguridad
# Se utiliza para firmar los tokens JWT. Debe ser una cadena larga y aleatoria.
JWT_SECRET="aurum-secret-key-change-in-prod"

# API Key de Google Gemini (Requerida para OCR de licencias y reportes inteligentes)
GEMINI_API_KEY=""

# Configuración de Servidor
# IMPORTANTE: Se recomienda usar 5000 para desarrollo y producción
PORT=5000
NODE_ENV="development"

# Configuración de Redis (Requerida para caché de estadísticas y auditoría rápida)
REDIS_URL="redis://localhost:6379"

# Integración de WhatsApp (WAHA)
# URL del servicio WAHA Plus/Core
WAHA_URL="http://localhost:3000"
